# ────────────────────────────────────────────────────────────────────────────────
# MNEME Environment Configuration
# Copy to .env and fill in values. Never commit .env to source control.
# ────────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (REQUIRED) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://mneme:password@localhost:5432/mneme
# Optional: separate test database for E2E tests
TEST_DATABASE_URL=postgresql://mneme:password@localhost:5432/mneme_test

# ── Redis (optional — degraded to no-cache mode if absent) ───────────────────
REDIS_URL=redis://localhost:6379
# For production with password:
# REDIS_URL=redis://:your-redis-password@localhost:6379

# ── Neo4j (optional — graph features disabled if absent) ─────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── API Configuration ──────────────────────────────────────────────────────────
API_PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Secret for JWT signing — must be long random string in production
# Generate: openssl rand -hex 64
JWT_SECRET=dev-secret-change-in-production-use-openssl-rand-hex-64

# Secret for AES-256-GCM memory encryption (SEPARATE from JWT_SECRET)
# Used by deriveVaultKey() to derive per-vault encryption keys via HKDF-SHA256.
# Must be at minimum 32 characters. NEVER use a predictable value or share with JWT_SECRET.
# Generate: openssl rand -hex 64
ENCRYPTION_SECRET=dev-encryption-secret-change-in-production-min-32-chars

# Salt for API key hashing (legacy — may be removed in future)
API_KEY_SALT=dev-salt-change-in-production

# CORS — comma-separated origins or * for development only.
# In production (NODE_ENV=production) this MUST be set to a specific origin.
# Wildcard (*) is blocked in production to prevent CSRF/CORS credential leakage.
# Example: CORS_ORIGIN=https://app.mneme.xyz
CORS_ORIGIN=http://localhost:3000

# ── Monad L1 Blockchain (optional — attestations queued locally if absent) ────
# Testnet RPC
MONAD_RPC_URL=https://rpc-devnet.monad.xyz

# Private key for submitting attestations (hex, with 0x prefix)
MONAD_PRIVATE_KEY=

# Deployed contract addresses (from npx hardhat run scripts/deploy.ts --network monad-testnet)
VAULT_REGISTRY_ADDRESS=
ATTESTATION_AGGREGATOR_ADDRESS=
MEMORY_MARKET_ADDRESS=
DELETION_PROVER_ADDRESS=

# Monad blockchain explorer base URL (for attestation explorer links)
MONAD_EXPLORER_URL=https://explorer.monad.xyz

# ── Embedding (optional — fallback to importance ordering if absent) ──────────
OPENAI_API_KEY=sk-...

# ── Extraction / Knowledge Graph (optional) ───────────────────────────────────
# Primary: Anthropic Claude Haiku (used by Python extraction service)
ANTHROPIC_API_KEY=sk-ant-...

# URL of the Python extraction microservice
# Development: http://localhost:8001
# Docker Compose: http://extraction:8001 (set automatically)
EXTRACTION_SERVICE_URL=http://localhost:8001

# ── Web Dashboard ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/v1

# ── Production PostgreSQL (used in docker-compose.prod.yml) ──────────────────
POSTGRES_DB=mneme
POSTGRES_USER=mneme
POSTGRES_PASSWORD=change-in-production

# ── Production Redis Password ─────────────────────────────────────────────────
REDIS_PASSWORD=change-in-production

# ── Production Neo4j Password ────────────────────────────────────────────────
# NEO4J_PASSWORD (same as NEO4J_PASSWORD above, listed for compose clarity)

# ── Backup Script ─────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
BACKUP_RETENTION_DAYS=7
