{
  "manifest_version": 3,
  "name": "MNEME Context Engine",
  "version": "1.0.0",
  "description": "Injects context-aware memories into consumer AI interfaces without proxying your traffic.",
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "*://chatgpt.com/*",
    "*://claude.ai/*",
    "*://gemini.google.com/*"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Configure MNEME"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://gemini.google.com/*"
      ],
      "js": ["src/content.js"],
      "run_at": "document_end"
    }
  ]
}
